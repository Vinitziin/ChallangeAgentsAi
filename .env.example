# === LLM ===
OPENAI_API_KEY=sk-...

# === Tavily (Web Search) ===
TAVILY_API_KEY=tvly-...

# === OpenWeatherMap ===
OPENWEATHER_API_KEY=...

# LangSmith Evaluation & Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=multi_agent_assistant_evals

# === PostgreSQL ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=assistant_db

# === ChromaDB ===
CHROMA_HOST=chroma
CHROMA_PORT=8000
